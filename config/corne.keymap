#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

#define DEF 0
#define LWR 1
#define RSE 2
#define ADJ 3
#define TCH 4

&lt { quick_tap_ms = <140>; };

&mt { quick_tap_ms = <120>; };

&sk {
    release-after-ms = <2000>;
    quick-release;
};

/ {
    combos { compatible = "zmk,combos"; };
};

/ {
    behaviors {
        td_1_11: td_1_11 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_1_11";
            #binding-cells = <0>;
            bindings = <&kp LC(KP_N1)>, <&kp LA(LC(KP_N1))>;

            tapping-term-ms = <300>;
        };

        td_3_13: td_3_13 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_3_13";
            #binding-cells = <0>;
            bindings = <&kp LC(KP_N3)>, <&kp LA(LC(KP_N3))>;

            tapping-term-ms = <300>;
        };

        td_4_14: td_4_14 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_4_14";
            #binding-cells = <0>;
            bindings = <&kp LC(KP_N4)>, <&kp LA(LC(KP_N4))>;

            tapping-term-ms = <300>;
        };

        td_2_12: td_2_12 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_2_12";
            #binding-cells = <0>;
            bindings = <&kp LC(KP_N2)>, <&kp LA(LC(KP_N2))>;

            tapping-term-ms = <300>;
        };

        td_5_15: td_5_15 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_5_15";
            #binding-cells = <0>;
            bindings = <&kp LC(KP_N5)>, <&kp LA(LC(KP_N5))>;

            tapping-term-ms = <300>;
        };

        td_6_16: td_6_16 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_6_16";
            #binding-cells = <0>;
            bindings = <&kp LC(KP_N6)>, <&kp LA(LC(KP_N6))>;

            tapping-term-ms = <300>;
        };

        td_7_17: td_7_17 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_7_17";
            #binding-cells = <0>;
            bindings = <&kp LC(KP_N7)>, <&kp LA(LC(KP_N7))>;

            tapping-term-ms = <300>;
        };

        td_8_18: td_8_18 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_8_18";
            #binding-cells = <0>;
            bindings = <&kp LC(KP_N8)>, <&kp LA(LC(KP_N8))>;

            tapping-term-ms = <300>;
        };

        td_9_19: td_9_19 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_9_19";
            #binding-cells = <0>;
            bindings = <&kp LC(KP_N9)>, <&kp LA(LC(KP_N9))>;

            tapping-term-ms = <300>;
        };

        td_10_20: td_10_20 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_10_20";
            #binding-cells = <0>;
            bindings = <&kp LC(KP_N0)>, <&kp LA(LC(KP_N0))>;

            tapping-term-ms = <300>;
        };

        super_key_behavior: super_key_behavior {
            compatible = "zmk,behavior-hold-tap";
            label = "SUPER_KEY_BEHAVIOR";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <240>;
            require-prior-idle-ms = <175>;
            hold-trigger-key-positions = <35>;
            quick-tap-ms = <175>;
        };

        hold_tap_advanced: hold_tap_advanced {
            compatible = "zmk,behavior-hold-tap";
            label = "HOLD_TAP_ADVANCED";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <240>;
            require-prior-idle-ms = <200>;
            quick-tap-ms = <175>;
        };

        mt_advanced: mt_advanced {
            compatible = "zmk,behavior-hold-tap";
            label = "MT_ADVANCED";
            bindings = <&mo>, <&kp>;

            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <280>;
            require-prior-idle-ms = <200>;
            quick-tap-ms = <175>;
        };
    };

    macros {
        claude_resume: reset {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp FSLH &kp R &kp E &kp S &kp U &kp M &kp E>;
            label = "RESET";
        };

        claude_status: claude_status {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp FSLH &kp S &kp T &kp A &kp T &kp U &kp S>;
            label = "CLAUDE_STATUS";
        };

        docker_comp: docker_comp {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp D &kp O &kp C &kp K &kp E &kp R &kp MINUS &kp C &kp O &kp M &kp P &kp O &kp S &kp E>;
            label = "DOCKER_COMP";
        };

        clear: clear {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp C &kp L &kp E &kp A &kp R>;
            label = "CLEAR";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&mt LG(LS(LA(LCTRL))) LC(V)  &super_key_behavior LG(W) Q      &kp W                          &kp E                        &kp R                            &super_key_behavior LG(LS(Z)) T  &super_key_behavior LG(Y) Y     &super_key_behavior LA(U) U       &kp I                           &super_key_behavior LG(O) O       &kp P     &super_key_behavior LS(LG(T)) LBKT
&kp LC(C)                    &super_key_behavior LG(A) A      &kp S                          &super_key_behavior LG(D) D  &super_key_behavior LG(LS(F)) F  &kp G                            &kp H                           &kp J                             &kp K                           &kp L                             &kp SEMI  &kp SQT
&kp RG(SPACE)                &super_key_behavior LG(LA(Z)) Z  &hold_tap_advanced LEFT_ALT X  &hold_tap_advanced LCTRL C   &hold_tap_advanced LEFT_SHIFT V  &hold_tap_advanced LEFT_GUI B    &hold_tap_advanced RIGHT_GUI N  &hold_tap_advanced RIGHT_SHIFT M  &hold_tap_advanced RCTRL COMMA  &hold_tap_advanced RIGHT_ALT DOT  &kp FSLH  &kp BSLH
                                                                                             &mt LSHIFT DEL               &mt_advanced 4 SPACE             &lt 1 TAB                        &lt 3 ESC                       &lt 2 RET                         &mt RSHIFT BSPC
            >;
        };

        lower_layer {
            bindings = <
&super_key_behavior LG(LC(P)) LG(P)  &none                                        &kp LG(F4)                                   &kp LG(TAB)                                  &super_key_behavior LG(LS(G)) LG(G)          &super_key_behavior LG(LS(S)) LG(S)          &none   &kp N7  &kp N8    &kp N9  &none    &none
&super_key_behavior LG(LC(N)) LG(N)  &super_key_behavior LA(LC(KP_N1)) LC(KP_N1)  &super_key_behavior LC(LA(KP_N2)) LC(KP_N2)  &super_key_behavior LC(LA(KP_N3)) LC(KP_N3)  &super_key_behavior LC(LA(KP_N4)) LC(KP_N4)  &super_key_behavior LC(LA(KP_N5)) LC(KP_N5)  &none   &kp N4  &kp N5    &kp N6  &kp DOT  &none
&super_key_behavior LG(LC(I)) LG(I)  &super_key_behavior LC(LA(KP_N6)) LC(KP_N6)  &super_key_behavior LC(LA(KP_N7)) LC(KP_N7)  &super_key_behavior LC(LA(KP_N8)) LC(KP_N8)  &super_key_behavior LA(LC(KP_N9)) LC(KP_N9)  &super_key_behavior LC(LA(KP_N0)) LC(KP_N0)  &none   &kp N1  &kp N2    &kp N3  &kp N0   &none
                                                                                                                               &lt 5 TAB                                    &trans                                       &trans                                       &trans  &trans  &kp BSPC
            >;
        };

        raise_layer {
            bindings = <
&none    &kp EQUAL   &kp LS(EQUAL)  &none       &none       &none       &kp LG(LS(P))  &none       &none       &kp MINUS   &kp LS(MINUS)  &kp RBKT
&none    &kp LS(N1)  &kp LS(N2)     &kp LS(N3)  &kp LS(N4)  &kp LS(N5)  &kp LS(N6)     &kp LS(N7)  &kp LS(N8)  &kp LS(N9)  &kp LS(N0)     &none
&kp F12  &kp F1      &kp F2         &kp F3      &kp F4      &kp F5      &kp F6         &kp F7      &kp F8      &kp F9      &kp F10        &kp F11
                                    &trans      &trans      &trans      &trans         &trans      &trans
            >;
        };

        adjust_layer {
            bindings = <
&kp GRAVE  &none                                                &none                                                &none                                                &none                                                &none                                                &none     &none     &none      &none      &none       &kp K_VOLUME_UP
&none      &super_key_behavior LS(LA(LC(KP_N1))) LS(LC(KP_N1))  &super_key_behavior LS(LC(LA(KP_N2))) LS(LC(KP_N2))  &super_key_behavior LS(LA(LC(KP_N3))) LS(LC(KP_N3))  &super_key_behavior LS(LA(LC(KP_N4))) LS(LC(KP_N4))  &super_key_behavior LA(LC(LS(KP_N5))) LS(LC(KP_N5))  &kp LEFT  &kp DOWN  &kp UP     &kp RIGHT  &kp K_NEXT  &kp K_PP
&kp TILDE  &super_key_behavior LS(LC(LA(KP_N6))) LS(LC(KP_N6))  &super_key_behavior LS(LA(LC(KP_N7))) LS(LC(KP_N7))  &super_key_behavior LS(LA(LC(KP_N8))) LS(LC(KP_N8))  &super_key_behavior LA(LC(LS(KP_N9))) LS(LC(KP_N9))  &super_key_behavior LA(LC(LS(KP_N0))) LS(LC(KP_N0))  &none     &kp HOME  &kp END    &none      &kp K_PREV  &kp K_VOL_DN
                                                                                                                     &trans                                               &sk LGUI                                             &trans                                               &trans    &trans    &lt 5 TAB
            >;
        };

        macros {
            bindings = <
&kp ESCAPE  &none   &none           &kp UP_ARROW  &claude_resume  &kp BACKSPACE       &trans  &trans  &trans  &trans  &trans  &trans
&kp F5      &kp F6  &kp LEFT_ARROW  &kp DOWN      &kp RIGHT       &kp ENTER           &trans  &trans  &trans  &trans  &trans  &trans
&trans      &trans  &trans          &none         &trans          &kp LA(LEFT_ARROW)  &trans  &trans  &trans  &trans  &trans  &trans
                                    &trans        &trans          &trans              &trans  &trans  &trans
            >;
        };

        tech_layer {
            bindings = <
&bootloader  &none         &none         &none         &none         &tog 6        &none         &none         &none         &none         &none         &bootloader
&bt BT_CLR   &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &bt BT_SEL 4  &bt BT_SEL 3  &bt BT_SEL 2  &bt BT_SEL 1  &bt BT_SEL 0  &bt BT_CLR
&sys_reset   &none         &none         &none         &none         &none         &none         &none         &none         &none         &none         &sys_reset
                                         &trans        &none         &trans        &none         &trans        &trans
            >;
        };

        shooter {
            bindings = <
&kp N1  &kp TAB    &kp Q  &kp W     &kp E      &kp R  &kp Y    &kp U      &kp I      &kp O    &kp P     &tog 6
&kp N2  &kp LSHFT  &kp A  &kp S     &kp D      &kp F  &kp H    &kp J      &kp K      &kp L    &kp SEMI  &trans
&kp N3  &kp LCTRL  &kp Z  &kp X     &kp C      &kp V  &kp N    &kp M      &kp COMMA  &kp DOT  &kp FSLH  &trans
                          &kp LALT  &kp SPACE  &mo 7  &kp ESC  &kp ENTER  &kp BSPC
            >;
        };

        shooter2 {
            bindings = <
&kp N4  &kp N7  &trans  &kp ESC  &kp M   &kp T   &trans  &trans  &trans  &trans  &trans  &trans
&kp N5  &kp N8  &trans  &trans   &none   &kp G   &trans  &trans  &trans  &trans  &trans  &trans
&kp N6  &kp N9  &trans  &trans   &trans  &kp B   &trans  &trans  &trans  &trans  &trans  &trans
                        &tog 6   &trans  &trans  &trans  &trans  &trans
            >;
        };
    };
};
